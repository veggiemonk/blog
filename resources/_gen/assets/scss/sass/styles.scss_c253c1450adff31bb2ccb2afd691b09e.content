  padding: 0 0 0 44px; }
  ol ol,
  ol ul,
  ul ol,
  ul ul {
    margin: 0; }

figure {
  margin: 1.40909091rem 0; }

hr {
  box-sizing: content-box;
  height: 0;
  overflow: visible; }

p,
pre {
  margin: 1.05681818rem 0; }

code,
kbd,
samp, pre {
