      font-size: 0.77777778rem;
      line-height: 1.40909091rem; } }
h1,
h2,
h3,
th,
nav,
label,
legend,
article > header,
.content-dates,
.header,
.footer {
  font-family: Futura, "Century Gothic", AppleGothic, sans-serif;
